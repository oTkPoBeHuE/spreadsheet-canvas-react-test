{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "formatter": {
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "noNonNullAssertion": "error",
        "useConst": "warn"
      }
    }
  },
  "css": {
    "linter": {
      "enabled": false
    }
  },
  "files": {
    "ignore": [
      "dist/**",
      "node_modules/**"
    ],
    "maxSize": "10MB"
  }
}
